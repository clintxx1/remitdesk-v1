# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tesseract model copied in for the Node OCR harness (npm run ocr)
/eng.traineddata

# local sample photos used for OCR testing — private, keep out of the repo
/samples/
