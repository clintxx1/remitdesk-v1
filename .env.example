# Optional: free AI extraction via Google Gemini.
# Without this, RemitDesk runs fully offline on Tesseract OCR.
#
# Get a key — no credit card, no charges — at https://aistudio.google.com/apikey
# Then copy this file to .env.local and paste your key below.
GEMINI_API_KEY=

# Optional: pick any free-tier vision model from AI Studio (default: gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash
